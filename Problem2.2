def product(M, N):
    R = [[0, 0], [0, 0]]
    for i in range(2):
        for j in range(2):
            for k in range(2):
                R[i][j] += M[i][k] * N[k][j]
    return R
    
def add(M, N):
    R = [[0, 0], [0, 0]]
    for i in range(2):
        for j in range(2):
            R[i][j] = M[i][j] + N[i][j]
    return R
    
def scalar_mul(k, M):
    R = [[0, 0], [0, 0]]
    for i in range(2):
        for j in range(2):
            R[i][j] = k * M[i][j]
    return R
    
def compute(n):
    A = [[3, -4], [2, -1]]
    B = [[2, -3], [1, 4]]
    if n == 0:
        return [[1, 0], [0, 1]], [[0, 0], [0, 0]]
    A_n = A
    B_n = scalar_mul(-1, B)
    for i in range(1, n):
        A_next = add(product(A_n, A), scalar_mul(-13, product(B_n, B)))
        B_next = add(product(B_n, A), product(A_n, B))
        A_n = A_next
        B_n = B_next
    return A_n, B_n
    
n = int(input("Nhap n: "))
A_n, B_n = compute(n)
print("A_n:")
for row in A_n:
    print(row)
print("B_n:")
for row in B_n:
    print(row)